# Generated by scripts/package-arch.mjs from packaging/arch/PKGBUILD.in.
# This recipe consumes only the adjacent local source archive and checksum.
pkgname=@NAME@
pkgver=@VERSION@
pkgrel=1
pkgdesc='Local loopback Codex App port for Omarchy/Linux'
arch=('any')
license=('custom')
depends=('nodejs')
optdepends=('codex: official Codex CLI/app-server provider')
options=('!strip')
source=('@ARCHIVE_FILENAME@')
sha256sums=('@SHA256@')

package() {
  local srcroot="${srcdir}/${pkgname}-${pkgver}"
  local appdir="${pkgdir}/opt/codex-app-port"

  install -dm755 "$appdir"
  cp -a "$srcroot/." "$appdir/"

  install -dm755 "${pkgdir}/usr/share/applications"
  install -Dm644 "$srcroot/packaging/omarchy/codex-app-port.desktop" \
    "${pkgdir}/usr/share/applications/codex-app-port.desktop"
}
